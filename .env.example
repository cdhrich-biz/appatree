# 실제 값은 .env.local 에 저장합니다. 절대 커밋 금지.
# Vercel 배포 시에는 Project Settings → Environment Variables 에 같은 이름으로 등록하세요.

# ─── 필수 (핵심 동작) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://...@...supabase.com:6543/postgres
JWT_SECRET=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
VITE_APP_ID=

# ─── LLM (AI 추천/대화) ────────────────────────────────────────────────────
BUILT_IN_FORGE_API_KEY=sk-...
BUILT_IN_FORGE_API_URL=
LLM_MODEL=gpt-4o-mini

# ─── 유튜브 검색 ───────────────────────────────────────────────────────────
YOUTUBE_API_KEY=

# ─── Supabase ───────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# 클라이언트에서 Supabase Auth(카카오 로그인) 사용에 필요
# SUPABASE_URL과 동일한 값, SUPABASE_ANON_KEY와 동일한 값을 VITE_ prefix로 한 번 더 설정
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── 원격 가족 지원 ────────────────────────────────────────────────────────
# Ably (https://ably.com) — 무료 200 동시접속 tier로 100 세션 동시 지원 가능
ABLY_API_KEY=appId.keyName:secret

# Metered TURN (https://metered.ca) — NAT 환경 음성통화 안정성, 무료 50GB/월
# 미설정 시 Google STUN fallback (같은 네트워크·공용망에서는 대부분 연결됨)
METERED_TURN_KEY=
METERED_TURN_DOMAIN=your-subdomain.metered.live
